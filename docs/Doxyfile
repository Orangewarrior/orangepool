PROJECT_NAME           = "OrangePool"
PROJECT_BRIEF          = "A pthread-based bounded thread pool in C"
OUTPUT_DIRECTORY       = docs
OUTPUT_LANGUAGE        = English

INPUT                  = include/orangepool.h src/orangepool.c docs/mainpage.dox docs/tests.dox docs/example_usage.dox
FILE_PATTERNS          = *.h *.c *.dox
RECURSIVE              = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

FULL_PATH_NAMES        = NO
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
GENERATE_TREEVIEW      = YES
HTML_OUTPUT            = html
